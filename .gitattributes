# Consistent line endings
*.md text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.json text eol=lf

# Ticketbook: counter files use 'ours' merge to avoid conflicts
# After merging, run `ticketbook doctor --fix` to reconcile counters
.ticketbook/tasks/.counter merge=ours
.ticketbook/plans/.counter merge=ours
.ticketbook/docs/.counter merge=ours
